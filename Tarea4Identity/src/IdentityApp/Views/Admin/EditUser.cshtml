@model EditUserViewModel
@{
    ViewData["Title"] = "Editar Usuario";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="d-flex align-items-center mb-3">
            <a asp-action="Index" class="btn btn-link text-muted ps-0">
                <i class="bi bi-arrow-left me-1"></i>Volver
            </a>
        </div>

        <div class="card p-4">
            <h5 class="fw-bold mb-4"><i class="bi bi-pencil-fill text-primary me-2"></i>Editar Usuario</h5>

            <form asp-action="EditUser" method="post">
                <input asp-for="Id" type="hidden" />
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                <div class="row g-2 mb-3">
                    <div class="col">
                        <label asp-for="FirstName" class="form-label fw-medium"></label>
                        <input asp-for="FirstName" class="form-control" />
                    </div>
                    <div class="col">
                        <label asp-for="LastName" class="form-label fw-medium"></label>
                        <input asp-for="LastName" class="form-control" />
                    </div>
                </div>

                <div class="mb-4">
                    <label asp-for="Email" class="form-label fw-medium"></label>
                    <input asp-for="Email" class="form-control" />
                </div>

                <div class="mb-4">
                    <label class="form-label fw-medium">Roles asignados</label>
                    <div class="border rounded p-3">
                        @foreach (var role in Model.AllRoles)
                        {
                            var isChecked = Model.UserRoles.Contains(role);
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" 
                                       name="SelectedRoles" value="@role"
                                       id="role_@role" @(isChecked ? "checked" : "") />
                                <label class="form-check-label" for="role_@role">
                                    @role
                                    @if (role == "Admin")
                                    {
                                        <span class="badge bg-danger ms-1 small">Administrador</span>
                                    }
                                </label>
                            </div>
                        }
                    </div>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2 me-1"></i>Guardar cambios
                    </button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </div>
            </form>
        </div>
    </div>
</div>
