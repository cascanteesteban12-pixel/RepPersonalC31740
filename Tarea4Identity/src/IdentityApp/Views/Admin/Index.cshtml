@model List<UserListViewModel>
@{
    ViewData["Title"] = "Gestión de Usuarios";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="fw-bold mb-0"><i class="bi bi-people-fill text-primary me-2"></i>Usuarios (@Model.Count)</h4>
    <a asp-action="Roles" class="btn btn-outline-primary btn-sm">
        <i class="bi bi-tags me-1"></i>Gestionar Roles
    </a>
</div>

<div class="card">
    <div class="table-responsive">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>Nombre</th>
                    <th>Email</th>
                    <th>Roles</th>
                    <th>Registrado</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td class="fw-medium">@user.FullName</td>
                        <td class="text-muted small">@user.Email</td>
                        <td>
                            @foreach (var role in user.Roles)
                            {
                                var badgeClass = role == "Admin" ? "bg-danger" : role == "Manager" ? "bg-warning text-dark" : "bg-secondary";
                                <span class="badge @badgeClass me-1">@role</span>
                            }
                        </td>
                        <td class="text-muted small">@user.CreatedAt.ToString("dd/MM/yyyy")</td>
                        <td>
                            @if (user.EmailConfirmed)
                            {
                                <span class="badge bg-success-subtle text-success">Activo</span>
                            }
                            else
                            {
                                <span class="badge bg-warning-subtle text-warning">Pendiente</span>
                            }
                        </td>
                        <td>
                            <a asp-action="EditUser" asp-route-id="@user.Id"
                               class="btn btn-sm btn-outline-secondary me-1">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form asp-action="DeleteUser" asp-route-id="@user.Id" method="post" class="d-inline"
                                  onsubmit="return confirm('¿Eliminar usuario @user.FullName?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
