@model ChangePasswordViewModel
@{
    ViewData["Title"] = "Cambiar contraseña";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card p-4 mt-3">
            <h5 class="fw-bold mb-4"><i class="bi bi-key-fill text-primary me-2"></i>Cambiar contraseña</h5>

            <form asp-action="ChangePassword" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                <div class="mb-3">
                    <label asp-for="OldPassword" class="form-label fw-medium"></label>
                    <input asp-for="OldPassword" class="form-control" />
                    <span asp-validation-for="OldPassword" class="text-danger small"></span>
                </div>
                <div class="mb-3">
                    <label asp-for="NewPassword" class="form-label fw-medium"></label>
                    <input asp-for="NewPassword" class="form-control" />
                    <span asp-validation-for="NewPassword" class="text-danger small"></span>
                </div>
                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                    <input asp-for="ConfirmPassword" class="form-control" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100">Actualizar contraseña</button>
                <a asp-action="Profile" class="btn btn-link w-100 mt-2 text-muted">Cancelar</a>
            </form>
        </div>
    </div>
</div>
