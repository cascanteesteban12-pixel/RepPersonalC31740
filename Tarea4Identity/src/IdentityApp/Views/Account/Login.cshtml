@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="row justify-content-center">
    <div class="col-md-4">
        <div class="card p-4 mt-3">
            <div class="text-center mb-4">
                <i class="bi bi-shield-lock-fill text-primary fs-1"></i>
                <h4 class="fw-bold mt-2">Iniciar sesión</h4>
            </div>

            <form asp-action="Login" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-medium"></label>
                    <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" autofocus />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-medium"></label>
                    <input asp-for="Password" class="form-control" placeholder="Tu contraseña" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4 form-check">
                    <input asp-for="RememberMe" class="form-check-input" type="checkbox" />
                    <label asp-for="RememberMe" class="form-check-label text-muted small"></label>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-box-arrow-in-right me-2"></i>Ingresar
                </button>
            </form>

            <div class="mt-3 p-3 bg-light rounded small text-muted">
                <strong>Credenciales de prueba (Admin):</strong><br />
                Email: <code>admin@identityapp.com</code><br />
                Pass: <code>Admin@1234</code>
            </div>

            <hr />
            <p class="text-center text-muted small mb-0">
                ¿No tienes cuenta? <a asp-action="Register">Regístrate</a>
            </p>
        </div>
    </div>
</div>
