@model RegisterViewModel
@{
    ViewData["Title"] = "Registrarse";
}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card p-4 mt-3">
            <div class="text-center mb-4">
                <i class="bi bi-person-plus-fill text-primary fs-1"></i>
                <h4 class="fw-bold mt-2">Crear cuenta</h4>
            </div>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger small py-2"></div>

                <div class="row g-2 mb-3">
                    <div class="col">
                        <label asp-for="FirstName" class="form-label fw-medium"></label>
                        <input asp-for="FirstName" class="form-control" placeholder="Juan" />
                        <span asp-validation-for="FirstName" class="text-danger small"></span>
                    </div>
                    <div class="col">
                        <label asp-for="LastName" class="form-label fw-medium"></label>
                        <input asp-for="LastName" class="form-control" placeholder="Pérez" />
                        <span asp-validation-for="LastName" class="text-danger small"></span>
                    </div>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-medium"></label>
                    <input asp-for="Email" class="form-control" placeholder="correo@ejemplo.com" />
                    <span asp-validation-for="Email" class="text-danger small"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Password" class="form-label fw-medium"></label>
                    <input asp-for="Password" class="form-control" placeholder="Mínimo 8 caracteres" />
                    <span asp-validation-for="Password" class="text-danger small"></span>
                </div>

                <div class="mb-4">
                    <label asp-for="ConfirmPassword" class="form-label fw-medium"></label>
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Repite tu contraseña" />
                    <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                </div>

                <button type="submit" class="btn btn-primary w-100 py-2">
                    <i class="bi bi-person-plus me-2"></i>Registrarse
                </button>
            </form>

            <hr />
            <p class="text-center text-muted small mb-0">
                ¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión</a>
            </p>
        </div>
    </div>
</div>
