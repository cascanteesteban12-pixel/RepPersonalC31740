@model ApplicationUser
@{
    ViewData["Title"] = "Mi Perfil";
    var roles = ViewBag.Roles as IList<string> ?? new List<string>();
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card p-4">
            <div class="text-center mb-4">
                <div class="bg-primary text-white rounded-circle d-inline-flex align-items-center justify-content-center mb-3"
                     style="width:80px;height:80px;font-size:2rem;">
                    @Model.FirstName[0]@Model.LastName[0]
                </div>
                <h4 class="fw-bold mb-0">@Model.FullName</h4>
                <p class="text-muted small">@Model.Email</p>
                <div>
                    @foreach (var role in roles)
                    {
                        <span class="badge bg-primary me-1">@role</span>
                    }
                </div>
            </div>

            <table class="table table-borderless small">
                <tr>
                    <td class="text-muted fw-medium">Usuario</td>
                    <td>@Model.UserName</td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Registrado</td>
                    <td>@Model.CreatedAt.ToString("dd/MM/yyyy")</td>
                </tr>
                <tr>
                    <td class="text-muted fw-medium">Email confirmado</td>
                    <td>
                        @if (Model.EmailConfirmed)
                        {
                            <span class="text-success"><i class="bi bi-check-circle-fill"></i> Sí</span>
                        }
                        else
                        {
                            <span class="text-warning"><i class="bi bi-clock"></i> Pendiente</span>
                        }
                    </td>
                </tr>
            </table>

            <a asp-action="ChangePassword" class="btn btn-outline-primary mt-2">
                <i class="bi bi-key me-2"></i>Cambiar contraseña
            </a>
        </div>
    </div>
</div>
